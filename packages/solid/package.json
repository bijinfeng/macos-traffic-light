{
  "name": "@traffic-light/solid",
  "version": "0.0.0",
  "description": "Solid components for macos-traffic-light.",
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack --from-vite && vp exec tsc -p tsconfig.build.json",
    "dev": "vp pack --from-vite --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@macos-traffic-light/svg": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "solid-js": "^1.9.0",
    "solid-testing-library": "^0.5.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  },
  "peerDependencies": {
    "solid-js": "^1.0.0"
  }
}
